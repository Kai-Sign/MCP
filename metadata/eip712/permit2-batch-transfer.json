{
  "$schema": "https://eips.ethereum.org/assets/eip-7730/erc7730-v2.schema.json",
  "context": {
    "eip712": {
      "domain": {
        "name": "Permit2",
        "chainId": 1,
        "verifyingContract": "0x000000000022d473030f116ddee9f6b43ac78ba3"
      },
      "primaryType": "PermitBatchTransferFrom",
      "types": {
        "EIP712Domain": [
          { "name": "name", "type": "string" },
          { "name": "chainId", "type": "uint256" },
          { "name": "verifyingContract", "type": "address" }
        ],
        "TokenPermissions": [
          { "name": "token", "type": "address" },
          { "name": "amount", "type": "uint256" }
        ],
        "PermitBatchTransferFrom": [
          { "name": "permitted", "type": "TokenPermissions[]" },
          { "name": "spender", "type": "address" },
          { "name": "nonce", "type": "uint256" },
          { "name": "deadline", "type": "uint256" }
        ]
      },
      "name": "Permit2 Batch Transfer From",
      "description": "Permit2 signature-based batch token transfer for multiple tokens"
    }
  },
  "display": {
    "formats": {
      "PermitBatchTransferFrom": {
        "intent": "Permit batch token transfer via Permit2",
        "interpolatedIntent": "Permit {spender} to transfer multiple tokens via Permit2",
        "fields": [
          { "path": "spender", "label": "Spender", "format": "addressName" },
          { "path": "nonce", "label": "Nonce", "format": "integer" },
          { "path": "deadline", "label": "Deadline", "format": "timestamp" }
        ]
      }
    }
  }
}
