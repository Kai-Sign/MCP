{
  "context": {
    "eip712": {
      "domain": {
        "name": "*",
        "version": "*",
        "chainId": 1,
        "verifyingContract": "*"
      },
      "primaryType": "Permit",
      "types": {
        "EIP712Domain": [
          { "name": "name", "type": "string" },
          { "name": "version", "type": "string" },
          { "name": "chainId", "type": "uint256" },
          { "name": "verifyingContract", "type": "address" }
        ],
        "Permit": [
          { "name": "owner", "type": "address" },
          { "name": "spender", "type": "address" },
          { "name": "value", "type": "uint256" },
          { "name": "nonce", "type": "uint256" },
          { "name": "deadline", "type": "uint256" }
        ]
      },
      "name": "ERC-2612 Permit",
      "description": "ERC-20 token permit (gasless approval)"
    }
  },
  "display": {
    "formats": {
      "Permit": {
        "intent": "Permit token spending",
        "fields": [
          { "path": "owner", "label": "Owner", "format": "address" },
          { "path": "spender", "label": "Spender", "format": "address" },
          { "path": "value", "label": "Amount", "format": "amount", "params": { "tokenPath": "$.domain.verifyingContract" } },
          { "path": "nonce", "label": "Nonce", "format": "integer" },
          { "path": "deadline", "label": "Deadline", "format": "timestamp" }
        ]
      }
    }
  }
}
