      "supply(address,uint256,uint256,address)": {
        "intent": "Supply to Morpho-Aave",
        "fields": [
          {
            "path": "#.underlying",
            "label": "Asset",
            "format": "addressName",
            "params": { "types": ["token"], "sources": null }
          },
          {
            "path": "#.amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": { "token": "#.underlying" }
          },
          {
            "path": "#.maxGasForMatching",
            "label": "Max Gas For Matching",
            "format": "raw"
          },
          {
            "path": "#.onBehalf",
            "label": "On Behalf Of",
            "format": "addressName",
            "params": { "types": ["wallet", "eoa"], "sources": ["local", "ens"] }
          }
        ],
        "required": ["#.underlying", "#.amount", "#.maxGasForMatching", "#.onBehalf"]
      },
      "borrow(address,uint256,uint256,uint256,address)": {
        "intent": "Borrow from Morpho-Aave",
        "fields": [
          {
            "path": "#.underlying",
            "label": "Asset",
            "format": "addressName",
            "params": { "types": ["token"], "sources": null }
          },
          {
            "path": "#.amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": { "token": "#.underlying" }
          },
          {
            "path": "#.maxGasForMatching",
            "label": "Max Gas For Matching",
            "format": "raw"
          },
          {
            "path": "#.receiver",
            "label": "Receiver",
            "format": "addressName",
            "params": { "types": ["wallet", "eoa"], "sources": ["local", "ens"] }
          }
        ],
        "required": ["#.underlying", "#.amount", "#.maxGasForMatching", "#.receiver"]
      },
      "repay(address,uint256,uint256,address)": {
        "intent": "Repay Morpho-Aave borrow",
        "fields": [
          {
            "path": "#.underlying",
            "label": "Asset",
            "format": "addressName",
            "params": { "types": ["token"], "sources": null }
          },
          {
            "path": "#.amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": { "token": "#.underlying" }
          },
          {
            "path": "#.onBehalf",
            "label": "On Behalf Of",
            "format": "addressName",
            "params": { "types": ["wallet", "eoa"], "sources": ["local", "ens"] }
          }
