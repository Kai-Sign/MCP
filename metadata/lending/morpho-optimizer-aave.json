        "required": ["#.underlying", "#.amount", "#.onBehalf"]
      },
      "withdraw(address,uint256,uint256,uint256,address)": {
        "intent": "Withdraw from Morpho-Aave",
        "fields": [
          {
            "path": "#.underlying",
            "label": "Asset",
            "format": "addressName",
            "params": { "types": ["token"], "sources": null }
          },
          {
            "path": "#.amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": { "token": "#.underlying" }
          },
          {
            "path": "#.receiver",
            "label": "Receiver",
            "format": "addressName",
            "params": { "types": ["wallet", "eoa"], "sources": ["local", "ens"] }
          }
        ],
        "required": ["#.underlying", "#.amount", "#.receiver"]
