{
  "$schema": "../../specs/erc7730-v1.schema.json",
  "context": {
    "$id": "MorphoOptimizerAave",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0x777777c9898d384f785ee44acfe945efdff5f3e0" }
      ],
      "abi": "https://github.com/LedgerHQ/ledger-asset-dapps/blob/main/ethereum/morpho/abis/0x777777c9898d384f785ee44acfe945efdff5f3e0.abi.json"
    }
  },
  "metadata": {
    "owner": "Morpho Labs",
    "info": {
      "legalName": "Morpho Labs",
      "url": "https://morpho.org"
    },
    "constants": {
      "WETHaddress": "0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2",
      "USDCaddress": "0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48",
