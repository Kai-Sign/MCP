  "display": {
    "formats": {
      "cancelOrder(uint256)": {
        "intent": "Cancel X2Y2 order",
        "fields": [
          {
            "path": "#.itemHash",
            "label": "Order Hash",
            "format": "raw",
            "visible": "always"
          }
        ]
      },
      "cancelOrders(uint256[])": {
        "intent": "Cancel multiple X2Y2 orders",
        "fields": [
          {
            "path": "#.itemHashes",
            "label": "Order Hashes",
            "format": "raw",
            "visible": "always"
          }
        ]
      }
    }
  }
}
