  "display": {
    "formats": {
      "transferTokens(address token,uint256 amount,uint16 recipientChain,bytes32 recipient,uint256 arbiterFee,uint32 nonce)": {
        "intent": "Bridge tokens via Wormhole",
        "interpolatedIntent": "Bridge {amount} {token} to chain {recipientChain} via Wormhole",
        "fields": [
          {
            "path": "token",
            "label": "Token",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "token"
            }
          },
          {
            "path": "recipientChain",
            "label": "Destination Chain",
            "format": "integer"
          },
          {
            "path": "arbiterFee",
            "label": "Arbiter Fee",
            "format": "raw"
          }
        ]
      },
      "transferTokensWithPayload(address token,uint256 amount,uint16 recipientChain,bytes32 recipient,uint32 nonce,bytes payload)": {
        "intent": "Bridge tokens with message via Wormhole",
        "interpolatedIntent": "Bridge {amount} {token} with payload to chain {recipientChain} via Wormhole",
        "fields": [
          {
            "path": "token",
            "label": "Token",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "token"
            }
          },
          {
            "path": "recipientChain",
            "label": "Destination Chain",
            "format": "integer"
          }
        ]
      },
      "completeTransfer(bytes encodedVm)": {
        "intent": "Complete inbound Wormhole transfer",
        "interpolatedIntent": "Complete inbound Wormhole token transfer",
        "fields": [
          {
            "path": "encodedVm",
            "label": "Signed VAA",
            "format": "raw"
          }
        ]
      }
    }
