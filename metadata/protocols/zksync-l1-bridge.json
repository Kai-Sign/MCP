        "interpolatedIntent": "Send {_l2Value} ETH to {_contractL2} on zkSync Era",
        "fields": [
          {
            "path": "_contractL2",
            "label": "L2 Recipient",
            "format": "addressName"
          },
          {
            "path": "_l2Value",
            "label": "ETH Value (L2)",
            "format": "ethAmount"
          },
          {
            "path": "_l2GasLimit",
            "label": "L2 Gas Limit",
            "format": "raw"
          },
          {
            "path": "_refundRecipient",
            "label": "Fee Refund Recipient",
            "format": "addressName"
          }
        ]
      },
      "finalizeEthWithdrawal(uint256,uint256,uint16,bytes,bytes32[])": {
        "intent": "Claim ETH withdrawal from zkSync Era to Ethereum",
        "interpolatedIntent": "Finalize ETH withdrawal from zkSync Era batch #{_l2BatchNumber}",
        "fields": [
          {
            "path": "_l2BatchNumber",
            "label": "L2 Batch Number",
            "format": "raw"
          },
          {
            "path": "_l2MessageIndex",
            "label": "Message Index",
            "format": "raw"
          }
        ]
      }
    }
