{
  "$schema": "../../specs/erc7730-v1.schema.json",
  "context": {
    "$id": "WormholeTokenBridge",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0x3ee18b2214aff97000d974cf647e7c347e8fa585" }
      ],
      "abi": "https://github.com/LedgerHQ/ledger-asset-dapps/blob/main/ethereum/wormhole/abis/0x3ee18b2214aff97000d974cf647e7c347e8fa585.abi.json"
    }
  },
  "metadata": {
    "owner": "Wormhole",
    "info": {
      "legalName": "Wormhole Foundation",
      "url": "https://wormhole.com"
    }
  },
  "display": {
    "formats": {
      "transferTokens(address,uint256,uint16,bytes32,uint256,uint32)": {
        "intent": "Bridge tokens via Wormhole",
        "fields": [
          {
            "path": "#.token",
            "label": "Token",
            "format": "addressName",
            "params": { "types": ["token"], "sources": null }
          },
          {
            "path": "#.amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": { "token": "#.token" }
          },
          {
            "path": "#.recipientChain",
            "label": "Destination Chain",
            "format": "raw"
          },
          {
            "path": "#.recipient",
            "label": "Recipient",
            "format": "raw"
          },
          {
            "path": "#.arbiterFee",
            "label": "Arbiter Fee",
            "format": "raw"
          }
        ],
        "required": ["#.token", "#.amount", "#.recipientChain", "#.recipient", "#.arbiterFee"]
      },
      "transferTokensWithPayload(address,uint256,uint16,bytes32,uint32,bytes)": {
        "intent": "Bridge tokens with payload via Wormhole",
        "fields": [
          {
            "path": "#.token",
            "label": "Token",
            "format": "addressName",
            "params": { "types": ["token"], "sources": null }
          },
          {
            "path": "#.amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": { "token": "#.token" }
          },
          {
            "path": "#.recipientChain",
            "label": "Destination Chain",
            "format": "raw"
          },
          {
            "path": "#.recipient",
            "label": "Recipient",
            "format": "raw"
          }
        ],
        "required": ["#.token", "#.amount", "#.recipientChain", "#.recipient"]
      },
      "completeTransfer(bytes)": {
        "intent": "Redeem bridged tokens from Wormhole",
        "fields": [
          {
            "path": "#.encodedVm",
            "label": "VAA",
            "format": "raw"
          }
        ],
        "required": ["#.encodedVm"]
      }
    }
  }
}
