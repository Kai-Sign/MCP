{
  "$schema": "../../specs/erc7730-v1.schema.json",
  "context": {
    "$id": "Optimism L1 Standard Bridge",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0x99c9fc46f92e8a1c0dec1b1747d010903e884be1" }
      ],
      "abi": "https://etherscan.io/address/0x99c9fc46f92e8a1c0dec1b1747d010903e884be1#code"
    }
  },
  "metadata": {
    "owner": "Optimism",
    "info": { "legalName": "OP Labs PBC", "url": "https://optimism.io/" }
  },
  "display": {
    "formats": {
      "depositETH(uint32,bytes)": {
        "intent": "Bridge ETH to Optimism",
        "fields": [
          { "path": "#._minGasLimit", "label": "Min Gas Limit", "format": "raw" },
          { "path": "#._extraData", "label": "Extra Data", "format": "raw" }
        ],
        "required": ["#._minGasLimit"],
        "excluded": []
      },
      "depositERC20(address,address,uint256,uint32,bytes)": {
        "intent": "Bridge ERC-20 to Optimism",
        "fields": [
          { "path": "#._l1Token", "label": "L1 Token", "format": "addressName", "params": { "types": ["token"], "sources": null } },
          { "path": "#._l2Token", "label": "L2 Token", "format": "addressName", "params": { "types": ["token"], "sources": null } },
          { "path": "#._amount", "label": "Amount", "format": "tokenAmount", "params": { "tokenPath": "_l1Token" } },
          { "path": "#._minGasLimit", "label": "Min Gas Limit", "format": "raw" }
        ],
        "required": ["#._l1Token", "#._l2Token", "#._amount", "#._minGasLimit"],
        "excluded": []
      },
      "depositETHTo(address,uint32,bytes)": {
        "intent": "Bridge ETH to Address on Optimism",
        "fields": [
          { "path": "#._to", "label": "Recipient on Optimism", "format": "addressName", "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] } },
          { "path": "#._minGasLimit", "label": "Min Gas Limit", "format": "raw" }
        ],
        "required": ["#._to", "#._minGasLimit"],
        "excluded": []
      },
      "depositERC20To(address,address,address,uint256,uint32,bytes)": {
        "intent": "Bridge ERC-20 to Address on Optimism",
        "fields": [
          { "path": "#._l1Token", "label": "L1 Token", "format": "addressName", "params": { "types": ["token"], "sources": null } },
          { "path": "#._l2Token", "label": "L2 Token", "format": "addressName", "params": { "types": ["token"], "sources": null } },
          { "path": "#._to", "label": "Recipient on Optimism", "format": "addressName", "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] } },
          { "path": "#._amount", "label": "Amount", "format": "tokenAmount", "params": { "tokenPath": "_l1Token" } },
          { "path": "#._minGasLimit", "label": "Min Gas Limit", "format": "raw" }
        ],
        "required": ["#._l1Token", "#._l2Token", "#._to", "#._amount", "#._minGasLimit"],
        "excluded": []
      }
    }
  }
}
