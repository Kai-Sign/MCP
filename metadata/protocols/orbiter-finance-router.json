{
  "$schema": "../../erc7730-v1.schema.json",
  "context": {
    "contract": {
      "address": "0xd9d74a29307cc6fc8bf424ee4217f1a587fbc8dc",
      "chainId": 1,
      "name": "Orbiter Finance Bridge Router",
      "abi": [
        {
          "type": "function",
          "name": "transfer",
          "selector": "0xa9059cbb",
          "inputs": [
            {
              "name": "to",
              "type": "address"
            },
            {
              "name": "amount",
              "type": "uint256"
            }
          ],
          "stateMutability": "payable"
        },
        {
          "type": "function",
          "name": "transferToken",
          "selector": "0x1e84f638",
          "inputs": [
            {
              "name": "token",
              "type": "address"
            },
            {
              "name": "to",
              "type": "address"
            },
            {
              "name": "amount",
              "type": "uint256"
            },
            {
              "name": "data",
              "type": "bytes"
            }
          ],
          "stateMutability": "nonpayable"
        },
        {
          "type": "function",
          "name": "transfer",
          "selector": "0x29723511",
          "inputs": [
            {
              "internalType": "address payable",
              "name": "_to",
              "type": "address"
            },
            {
              "internalType": "bytes",
              "name": "_ext",
              "type": "bytes"
            }
          ],
          "stateMutability": "payable"
        },
        {
          "type": "function",
          "name": "transferERC20",
          "selector": "0x46f506ad",
          "inputs": [
            {
              "internalType": "contract IERC20",
              "name": "_token",
              "type": "address"
            },
            {
              "internalType": "address",
              "name": "_to",
              "type": "address"
            },
            {
              "internalType": "uint256",
              "name": "_amount",
              "type": "uint256"
            },
            {
              "internalType": "bytes",
              "name": "_ext",
              "type": "bytes"
            }
          ],
          "stateMutability": "nonpayable"
        }
      ]
    }
  },
  "display": {
    "formats": {
      "transfer(address,uint256)": {
        "intent": "Bridge ETH via Orbiter Finance",
        "interpolatedIntent": "Bridge {amount} ETH via Orbiter Finance to {to}",
        "fields": [
          {
            "path": "to",
            "label": "Bridge Maker",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount (ETH, last 4 digits encode destination)",
            "format": "ethAmount"
          }
        ]
      },
      "transferToken(address,address,uint256,bytes)": {
        "intent": "Bridge ERC-20 tokens via Orbiter Finance",
        "interpolatedIntent": "Bridge {amount} {token} via Orbiter Finance to {to}",
        "fields": [
          {
            "path": "token",
            "label": "Token",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "token"
            }
          },
          {
            "path": "to",
            "label": "Bridge Maker",
            "format": "addressName"
          }
        ]
      },
      "transfer(address,bytes)": {
        "intent": "Review Transfer transaction",
        "fields": [
          {
            "path": "_to",
            "label": " to",
            "format": "address"
          },
          {
            "path": "_ext",
            "label": " ext",
            "format": "hex"
          }
        ]
      },
      "transferERC20(address,address,uint256,bytes)": {
        "intent": "Review Transfer ERC20 transaction",
        "fields": [
          {
            "path": "_token",
            "label": " token",
            "format": "address"
          },
          {
            "path": "_to",
            "label": " to",
            "format": "address"
          },
          {
            "path": "_amount",
            "label": " amount",
            "format": "raw"
          },
          {
            "path": "_ext",
            "label": " ext",
            "format": "hex"
          }
        ]
      }
    }
  },
  "metadata": {
    "owner": "Orbiter Finance",
    "info": {
      "url": "https://www.orbiter.finance/",
      "legalName": "Orbiter Finance",
      "lastUpdate": "2026-03-25"
    }
  }
}
