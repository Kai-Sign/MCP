  "metadata": {
    "owner": "Stargate Finance",
    "contractName": "Stargate V2 USDC Pool (Base)"
  },
  "display": {
    "formats": {
      "send((uint32 dstEid,bytes32 to,uint256 amountLD,uint256 minAmountLD,bytes extraOptions,bytes composeMsg,bytes oftCmd),(uint256 nativeFee,uint256 lzTokenFee),address refundAddress)": {
        "intent": "Bridge USDC via Stargate V2",
        "interpolatedIntent": "Bridge {sendParam.amountLD} USDC to chain {sendParam.dstEid} via Stargate V2",
        "fields": [
          {
            "path": "sendParam.dstEid",
            "label": "Destination Chain (LayerZero EID)",
            "format": "integer"
          },
          {
            "path": "sendParam.amountLD",
            "label": "Amount (USDC)",
            "format": "amount",
            "params": {
              "decimals": 6,
              "symbol": "USDC"
            }
          },
          {
            "path": "sendParam.minAmountLD",
            "label": "Min Amount Received",
            "format": "amount",
            "params": {
              "decimals": 6,
              "symbol": "USDC"
            }
          },
          {
            "path": "fee.nativeFee",
            "label": "Native Bridge Fee",
            "format": "amount",
            "params": {
              "decimals": 18,
              "symbol": "ETH"
            }
          },
          {
            "path": "refundAddress",
            "label": "Fee Refund Address",
            "format": "addressName"
          }
        ]
      },
      "deposit(address token,uint256 amount)": {
        "intent": "Add USDC liquidity to Stargate V2 pool",
        "interpolatedIntent": "Deposit {amount} USDC into Stargate V2 pool on Base",
        "fields": [
          {
            "path": "token",
            "label": "Token",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "amount",
            "params": {
              "decimals": 6,
              "symbol": "USDC"
            }
          }
        ]
      },
      "redeem(uint256 amountLD,address receiver)": {
        "intent": "Remove USDC liquidity from Stargate V2 pool",
        "interpolatedIntent": "Redeem {amountLD} USDC from Stargate V2 pool to {receiver}",
        "fields": [
          {
            "path": "amountLD",
            "label": "Amount to Redeem",
            "format": "amount",
            "params": {
              "decimals": 6,
              "symbol": "USDC"
            }
          },
          {
            "path": "receiver",
            "label": "Recipient",
            "format": "addressName"
          }
        ]
      }
    }
  }
}
