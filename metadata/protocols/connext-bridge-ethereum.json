  "display": {
    "formats": {
      "xcall(uint32,address,address,address,uint256,uint256,bytes)": {
        "intent": "Bridge tokens via Connext to another chain",
        "interpolatedIntent": "Bridge {_amount} {_asset} to chain {_destination} via Connext to {_to}",
        "fields": [
          {
            "path": "_asset",
            "label": "Asset",
            "format": "addressName"
          },
          {
            "path": "_amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "_asset"
            }
          },
          {
            "path": "_destination",
            "label": "Destination Domain",
            "format": "raw"
          },
          {
            "path": "_to",
            "label": "Recipient",
            "format": "addressName"
          },
          {
            "path": "_slippage",
            "label": "Max Slippage (bps)",
            "format": "raw"
          },
          {
            "path": "_delegate",
            "label": "Delegate",
            "format": "addressName"
          }
        ]
      },
      "xcallIntoLocal(uint32,address,address,address,uint256,uint256,bytes)": {
        "intent": "Bridge tokens via Connext (receive local asset)",
        "interpolatedIntent": "Bridge {_amount} {_asset} to chain {_destination} as local asset via Connext",
        "fields": [
          {
            "path": "_asset",
            "label": "Asset",
            "format": "addressName"
          },
          {
            "path": "_amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "_asset"
            }
          },
          {
            "path": "_destination",
            "label": "Destination Domain",
            "format": "raw"
          },
          {
            "path": "_to",
            "label": "Recipient",
            "format": "addressName"
          },
          {
            "path": "_slippage",
            "label": "Max Slippage (bps)",
            "format": "raw"
          }
        ]
      },
      "bumpTransfer(bytes32)": {
        "intent": "Add additional relayer fee to Connext transfer",
        "interpolatedIntent": "Bump relayer fee for Connext transfer {_transferId}",
        "fields": [
          {
            "path": "_transferId",
            "label": "Transfer ID",
            "format": "raw"
          }
        ]
      }
    }
  },
