  "display": {
    "formats": {
      "cook(uint8[] actions,uint256[] values,bytes[] datas)": {
        "intent": "Execute Abracadabra batch operation",
        "interpolatedIntent": "Execute batch operations on Abracadabra Cauldron",
        "fields": [
          {
            "path": "actions",
            "label": "Actions",
            "format": "raw"
          },
          {
            "path": "values",
            "label": "Values",
            "format": "raw"
          },
          {
            "path": "datas",
            "label": "Data",
            "format": "raw"
          }
        ]
      },
      "borrow(address to,uint256 amount)": {
        "intent": "Borrow MIM from Abracadabra",
        "interpolatedIntent": "Borrow {amount} MIM to {to}",
        "fields": [
          {
            "path": "to",
            "label": "Recipient",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "MIM Amount",
            "format": "amount",
            "params": {
              "decimals": 18,
              "symbol": "MIM"
            }
          }
        ]
      },
      "repay(address to,bool skim,uint256 part)": {
        "intent": "Repay MIM to Abracadabra",
        "interpolatedIntent": "Repay {part} MIM debt for {to}",
        "fields": [
          {
            "path": "to",
            "label": "Account",
            "format": "addressName"
          },
          {
            "path": "part",
            "label": "Debt Part",
            "format": "raw"
          }
        ]
      },
      "addCollateral(address to,bool skim,uint256 share)": {
        "intent": "Add collateral to Abracadabra Cauldron",
        "interpolatedIntent": "Add {share} collateral shares for {to}",
        "fields": [
          {
            "path": "to",
            "label": "Account",
            "format": "addressName"
          },
          {
            "path": "share",
            "label": "Collateral Shares",
            "format": "raw"
          }
        ]
      },
      "removeCollateral(address to,uint256 share)": {
        "intent": "Remove collateral from Abracadabra Cauldron",
        "interpolatedIntent": "Remove {share} collateral shares to {to}",
        "fields": [
          {
            "path": "to",
            "label": "Recipient",
            "format": "addressName"
          },
          {
            "path": "share",
            "label": "Collateral Shares",
            "format": "raw"
          }
        ]
      },
      "liquidate(address[] users,uint256[] maxBorrowParts,address to,address swapper)": {
        "intent": "Liquidate Abracadabra positions",
        "interpolatedIntent": "Liquidate undercollateralized positions on Abracadabra",
        "fields": [
          {
            "path": "users",
            "label": "Users to Liquidate",
            "format": "raw"
          },
          {
            "path": "maxBorrowParts",
            "label": "Max Borrow Parts",
            "format": "raw"
          },
          {
            "path": "to",
            "label": "Recipient",
            "format": "addressName"
          },
          {
            "path": "swapper",
            "label": "Swapper",
            "format": "addressName"
          }
        ]
      }
    }
