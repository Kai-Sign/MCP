  "display": {
    "formats": {
      "setUserEMode(uint8)": {
        "intent": "Set Efficiency Mode Category {categoryId}",
        "fields": [
          {
            "path": "categoryId",
            "label": "E-Mode Category",
            "format": "raw"
          }
        ]
      },
      "setReserveBorrowing(address,bool)": {
        "intent": "{enabled,select,true{Enable} other{Disable}} Borrowing",
        "fields": [
          {
            "path": "asset",
            "label": "Asset",
            "format": "tokenAmount"
          },
          {
            "path": "enabled",
            "label": "Enabled",
            "format": "raw"
          }
        ]
      },
      "configureReserveAsCollateral(address,uint256,uint256,uint256)": {
        "intent": "Configure Reserve as Collateral",
        "fields": [
          {
            "path": "asset",
            "label": "Asset",
            "format": "tokenAmount"
          },
          {
            "path": "ltv",
            "label": "LTV (bps)",
            "format": "raw"
          },
          {
            "path": "liquidationThreshold",
            "label": "Liq. Threshold (bps)",
            "format": "raw"
          },
          {
            "path": "liquidationBonus",
            "label": "Liq. Bonus (bps)",
            "format": "raw"
          }
        ]
      },
