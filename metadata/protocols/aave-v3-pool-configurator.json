        "intent": "Set E-Mode Category {label}",
        "fields": [
          {
            "path": "categoryId",
            "label": "Category ID",
            "format": "raw"
          },
          {
            "path": "ltv",
            "label": "LTV (bps)",
            "format": "raw"
          },
          {
            "path": "liquidationThreshold",
            "label": "Liq. Threshold (bps)",
            "format": "raw"
          },
          {
            "path": "liquidationBonus",
            "label": "Liq. Bonus (bps)",
            "format": "raw"
          },
          {
