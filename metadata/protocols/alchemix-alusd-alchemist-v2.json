  "metadata": {
    "owner": "Alchemix Finance",
    "contractName": "Alchemix alUSD AlchemistV2"
  },
  "display": {
    "formats": {
      "deposit(address yieldToken,uint256 amount,address recipient)": {
        "intent": "Deposit to Alchemix alUSD",
        "interpolatedIntent": "Deposit {amount} of yield token {yieldToken} to Alchemix for {recipient}",
        "fields": [
          {
            "path": "yieldToken",
            "label": "Yield Token",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "yieldToken"
            }
          },
          {
            "path": "recipient",
            "label": "Recipient",
            "format": "addressName"
          }
        ]
      },
      "depositUnderlying(address yieldToken,uint256 amount,address recipient,uint256 minimumAmountOut)": {
        "intent": "Deposit underlying to Alchemix alUSD",
        "interpolatedIntent": "Deposit {amount} underlying for {yieldToken} to Alchemix for {recipient}",
        "fields": [
          {
            "path": "yieldToken",
            "label": "Yield Token",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "raw"
          },
          {
            "path": "recipient",
            "label": "Recipient",
            "format": "addressName"
          },
          {
            "path": "minimumAmountOut",
            "label": "Min Amount Out",
            "format": "raw"
          }
        ]
      },
      "withdraw(address yieldToken,uint256 shares,address recipient)": {
        "intent": "Withdraw from Alchemix alUSD",
        "interpolatedIntent": "Withdraw {shares} shares of {yieldToken} from Alchemix to {recipient}",
        "fields": [
          {
            "path": "yieldToken",
            "label": "Yield Token",
            "format": "addressName"
          },
          {
            "path": "shares",
            "label": "Shares",
            "format": "raw"
          },
          {
            "path": "recipient",
            "label": "Recipient",
            "format": "addressName"
          }
        ]
