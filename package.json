{
  "name": "kaisign-mcp",
  "version": "1.0.0",
  "description": "KaiSign MCP Server - Verified transaction decoding for LLM agents using on-chain attested metadata",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kai-Sign/MCP.git"
  },
  "homepage": "https://github.com/Kai-Sign/MCP#readme",
  "bugs": {
    "url": "https://github.com/Kai-Sign/MCP/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ethereum",
    "transaction-decoding",
    "verification",
    "erc-7730",
    "clear-signing",
    "web3",
    "blockchain"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "ts-node --esm src/index.ts",
    "dev:http": "ts-node --esm src/http.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "cli": "node dist/cli.js",
    "metadata:from-etherscan": "node scripts/generate-erc7730-from-etherscan.mjs",
    "submission:keystore": "node scripts/submission-keystore.mjs",
    "mcp:sample": "node scripts/call-mcp-clear-sign-sample.mjs",
    "mcp:bridge": "scripts/start-browser-mcp-bridge.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "c-kzg": "^4.1.0",
    "ethers": "^6.9.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "js-tiktoken": "^1.0.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "kaisign": "dist/cli.js"
  }
}
